# Streamlit Cloud secrets — paste this content (with real values filled in)
# into your Streamlit Cloud dashboard under App settings → Secrets.
#
# Do NOT commit a real secrets.toml — see .gitignore.

KROGER_CLIENT_ID = ""
KROGER_CLIENT_SECRET = ""
# For Streamlit Cloud, set this to your app URL (must end with /):
#   https://<your-app>.streamlit.app/
# Must EXACTLY match the redirect URI registered in the Kroger dev portal.
KROGER_REDIRECT_URI = ""
# Optional — leave empty to pick a store via the in-app Find My Store flow.
KROGER_LOCATION_ID = ""

ANTHROPIC_API_KEY = ""
APP_PASSWORD = ""

SUPABASE_URL = ""
SUPABASE_SERVICE_KEY = ""
