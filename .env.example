# SmartCart — environment configuration template
# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Kroger Developer App ---
# Register at https://developer.kroger.com → Create App
# Production environment, API products: User, Cart, Location, Product
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# Must exactly match the redirect URI registered in the Kroger app.
# Local dev:           http://localhost:8501/
# Streamlit Cloud:     https://<your-app>.streamlit.app/
KROGER_REDIRECT_URI=http://localhost:8501/

# Optional — initial store location ID. After first run you can leave this
# blank and select your store via Find My Store; the choice is persisted in
# Supabase.
KROGER_LOCATION_ID=

# --- Anthropic ---
# Get a key at https://console.anthropic.com → Settings → API Keys
# Set a $10/month spending cap as a safety ceiling.
ANTHROPIC_API_KEY=

# --- App auth ---
# Single household password for the login screen.
APP_PASSWORD=

# --- Supabase persistence ---
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=

# service_role key (NOT the anon key) — used server-side only.
# Treat this like a database password.
SUPABASE_SERVICE_KEY=
